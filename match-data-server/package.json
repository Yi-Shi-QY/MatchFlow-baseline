{
  "name": "match-data-server",
  "version": "1.0.0",
  "description": "Simple match data server for MatchFlow",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "local:football": "node scripts/runLocalFootballServer.js",
    "seed:football:test": "node scripts/seedFootballTestData.js",
    "test": "node test/runAuthzIntegration.js",
    "test:db-phase": "node test/runDbPhaseGate.js",
    "test:phase-e": "node test/runPhaseEHardening.js",
    "test:football:smoke": "node test/runFootballDatasourceSmoke.js",
    "test:joint-smoke": "node test/runClientServerJointSmoke.js",
    "test:web-joint-smoke": "node test/runAdminStudioWebJointSmoke.js",
    "test:prod-ready": "node test/runProductionReadiness.js",
    "test:prod-ready:file": "node scripts/runProductionReadinessFromEnvFile.js",
    "preflight:prod": "node scripts/preflightProd.js",
    "preflight:prod:file": "node scripts/preflightProdFromEnvFile.js",
    "verify:prod:file": "npm run preflight:prod:file && npm run test:prod-ready:file",
    "env:prod:init": "node scripts/initProdEnv.js",
    "collect:jczq:sample": "node scripts/collectCnJczqSample.js",
    "collect:jczq:daemon": "node scripts/runCnJczqCollectorDaemon.js",
    "admin-web:dev": "npm --prefix admin-studio-web run dev",
    "admin-web:build": "npm --prefix admin-studio-web run build",
    "admin-web:lint": "npm --prefix admin-studio-web run lint",
    "admin-web:e2e": "npm --prefix admin-studio-web run test:e2e",
    "admin-web:e2e:headed": "npm --prefix admin-studio-web run test:e2e:headed",
    "admin-web:e2e:install": "npm --prefix admin-studio-web run test:e2e:install",
    "hash-password": "node scripts/hashPassword.js",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:reset": "docker compose -f docker-compose.db.yml down -v",
    "db:logs": "docker compose -f docker-compose.db.yml logs -f db"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}

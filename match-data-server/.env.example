PORT=3001
API_KEY=your-secret-key-here
DATABASE_URL=postgres://user:password@localhost:5432/matchflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=matchflow
POSTGRES_PORT=5432
POSTGRES_IMAGE=postgres:15-alpine
ACCESS_TOKEN_SECRET=replace-with-random-secret
REFRESH_TOKEN_SECRET=replace-with-another-random-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# Optional: override hub hint sent to clients.
# If empty, server uses the current request host/protocol.
HUB_BASE_URL=

# Optional: include API key in hub hint sent to client.
# Keep false by default for safety.
HUB_INCLUDE_API_KEY_HINT=false
HUB_API_KEY_HINT=

# Optional: client hint for auto-install behavior.
HUB_AUTO_INSTALL=true
